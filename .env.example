# Application
APP_NAME="AI Lead Intelligence Platform"
ENVIRONMENT=development
DEBUG=false
SECRET_KEY=changeme-use-a-long-random-string-in-production
CORS_ORIGINS=http://localhost:3000

# Database
POSTGRES_DB=leadintel
POSTGRES_USER=leadintel
POSTGRES_PASSWORD=leadintel
DATABASE_URL=postgresql+asyncpg://leadintel:leadintel@localhost:5432/leadintel

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@leadintel.io

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Enrichment Providers
CLEARBIT_API_KEY=
HUNTER_API_KEY=
APOLLO_API_KEY=

# AWS Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
